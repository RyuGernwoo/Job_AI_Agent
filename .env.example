# LessonPack AI local and deployment environment template
# Copy this file to `.env` and fill only local secret values.
# Do not commit `.env`.

# Application runtime defaults.
APP_NAME=lessonpack-ai
APP_ENV=development
DEBUG=true
SERVICE_PORT=8000
APP_IMAGE=lessonpack-ai:local
PYTHONPATH=src

# Browser UI integration. Comma-separated origins allowed by FastAPI CORS.
LESSONPACK_CORS_ALLOW_ORIGINS=https://lessonpack-ai.lovable.app,http://localhost:5173,http://127.0.0.1:5173
LESSONPACK_CORS_ALLOW_CREDENTIALS=false

# Optional: point commands to a different env file.
# LESSONPACK_ENV_FILE=.env

# Shared config file used by local FastAPI, Streamlit, evaluation scripts, and provider setup.
# GCE production deployment intentionally omits this value and uses env-only settings.
LESSONPACK_CONFIG=config.yaml

# Env-only provider fallback when LESSONPACK_CONFIG is not set.
LESSONPACK_LLM_PROVIDER=litellm
LESSONPACK_LITELLM_MODEL=gpt-4o-mini
LESSONPACK_LITELLM_FALLBACK_MODELS=gemini/gemini-2.0-flash
LESSONPACK_LITELLM_TIMEOUT_SECONDS=30
LESSONPACK_LITELLM_CALLBACKS=langfuse_otel

# Model API keys. Never commit real values.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Langfuse tracing for LiteLLM OTEL callback.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Required for production to avoid sending traces to the wrong Langfuse region.
# Current project uses Japan cloud. Use https://us.cloud.langfuse.com or https://cloud.langfuse.com if your project is in another region.
LANGFUSE_OTEL_HOST=https://jp.cloud.langfuse.com
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
LESSONPACK_LANGFUSE_TRACE_NAME=lessonpack-ai-mvp
LESSONPACK_LANGFUSE_GENERATION_NAME=lessonpack-ai-generation
LESSONPACK_LANGFUSE_SESSION_ID=lessonpack-ai-local
LESSONPACK_LANGFUSE_FLUSH_WAIT_SECONDS=1.0
# OTEL_EXPORTER_OTLP_ENDPOINT and OTEL_EXPORTER_OTLP_HEADERS are derived automatically at runtime.

# Backward-compatible key for direct http_chat/openai_compatible mode.
LESSONPACK_HTTP_API_KEY=

# LiteLLM logging. Use DEBUG only for local troubleshooting.
LITELLM_LOG=INFO

# Vector store runtime selection.
# Supported: memory, supabase
LECTUREOPS_VECTOR_STORE=memory

# Required only when LECTUREOPS_VECTOR_STORE=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LESSONPACK_SUPABASE_TABLE=lessonpack_chunks
LESSONPACK_SUPABASE_MATCH_FUNCTION=match_lessonpack_chunks
LESSONPACK_SUPABASE_MATCH_THRESHOLD=0.0

# GitHub Actions deployment secrets to register in repository settings, not in `.env`.
# GCE_HOST=
# GCE_USERNAME=
# GCE_SSH_KEY=
# SERVICE_PORT=8000
# LESSONPACK_CORS_ALLOW_ORIGINS=https://lessonpack-ai.lovable.app
# LESSONPACK_PUBLIC_API_HOST=api.example.com
